# Supabase 接続情報（プロジェクト作成後に設定）
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# マジックリンクのリダイレクト先（開発時。本番は本番URLに）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── デモ環境（flyerdemo）専用。本番 flyer では設定しないこと ──
# NEXT_PUBLIC_DEMO_MODE を "1" にすると、ログイン画面に「デモとしてログイン」ボタンが出る。
# NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_EMAIL=demo@example.com
# NEXT_PUBLIC_DEMO_PASSWORD=（デモ用アカウントのパスワード）
